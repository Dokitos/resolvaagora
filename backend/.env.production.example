# ═══════════════════════════════════════════════════════════════════
#  ResolvaAgora — Variáveis de PRODUÇÃO (Railway)
#  Copia estes valores para o painel de variáveis do Railway.
#  NÃO commitar o ficheiro .env real.
# ═══════════════════════════════════════════════════════════════════

NODE_ENV=production
PORT=3000                      # O Railway injeta a sua própria PORT — deixa o serviço usá-la.
API_PREFIX=api/v1

# ── Base de dados (Railway PostgreSQL) ──────────────────────────────
# O plugin PostgreSQL do Railway fornece esta variável automaticamente.
DATABASE_URL=${{Postgres.DATABASE_URL}}

# ── JWT (gerar segredos fortes: openssl rand -base64 48) ────────────
# NÃO commitar os valores reais — colar diretamente nas Variables do Railway.
JWT_SECRET=<colar-segredo-forte>
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=<colar-outro-segredo-forte>
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis (Railway Redis OU Upstash) ────────────────────────────────
# Railway Redis expõe REDISHOST/REDISPORT/REDISPASSWORD — mapeia assim:
REDIS_HOST=${{Redis.REDISHOST}}
REDIS_PORT=${{Redis.REDISPORT}}
REDIS_PASSWORD=${{Redis.REDISPASSWORD}}

# ── RabbitMQ (CloudAMQP — plano gratuito "Little Lemur") ────────────
RABBITMQ_URL=amqps://USER:PASS@HOST/VHOST

# ── Stripe (LIVE — obter em dashboard.stripe.com) ──────────────────
STRIPE_SECRET_KEY=sk_live_xxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxx

# ── Firebase (FCM — opcional; push do SO. Deixa placeholder p/ já) ──
FIREBASE_PROJECT_ID=placeholder
FIREBASE_CLIENT_EMAIL=placeholder@placeholder.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nplaceholder\n-----END PRIVATE KEY-----\n"

# ── Email (SMTP — ex.: SendGrid, Mailgun, ou o teu provedor) ───────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-smtp-password
SMTP_FROM=ResolvaAgora <noreply@resolvaagora.pt>

# ── Armazenamento de ficheiros (Cloudflare R2 / S3) ────────────────
STORAGE_ENDPOINT=https://your-account.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_BUCKET=resolvaagora-files
STORAGE_PUBLIC_URL=https://files.resolvaagora.pt

# ── URLs públicas (CORS / links) ───────────────────────────────────
FRONTEND_URL=https://resolvaagora.pt
ADMIN_URL=https://admin.resolvaagora.pt

# ── SLA (minutos) ──────────────────────────────────────────────────
SLA_FIRST_RESPONSE_WARNING=30
SLA_FIRST_RESPONSE_CRITICAL=60
SLA_ARRIVAL_WARNING=120
SLA_ARRIVAL_CRITICAL=240
SLA_RESOLUTION_WARNING=4320
SLA_RESOLUTION_CRITICAL=7200

QUOTE_EXPIRY_HOURS=48
